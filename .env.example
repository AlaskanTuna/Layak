# -- GCP / Vertex AI --
GOOGLE_CLOUD_PROJECT=layak-myaifuturehackathon
GOOGLE_CLOUD_LOCATION=global
VERTEX_AI_SEARCH_DATA_STORE=layak-schemes-v1
VERTEX_AI_SEARCH_LOCATION=global

# -- Per-step Gemini model assignment (overrides defaults in app/agents/gemini.py) --
# Uncomment to override; otherwise the values shipped in code are used.
# LAYAK_FAST_MODEL=gemini-3.1-flash-lite
# LAYAK_WORKER_MODEL=gemini-3.1-flash-lite
# LAYAK_HEAVY_MODEL=gemini-2.5-pro
# LAYAK_HEAVY_MODEL_FALLBACK=gemini-2.5-pro
# LAYAK_ORCHESTRATOR_MODEL=gemini-2.5-pro

# -- Free-tier rate-limit knobs (overrides defaults in app/services/rate_limit.py) --
# LAYAK_FREE_TIER_LIMIT=5
# LAYAK_FREE_TIER_WINDOW_HOURS=24

# -- Per-rule Vertex AI Search query strings (overrides defaults in app/rules/*.py) --
# Tune these to retune RAG retrieval without a redeploy.
# LAYAK_RAG_QUERY_STR_2026=Sumbangan Tunai Rahmah household tier with children
# LAYAK_RAG_QUERY_JKM_WARGA_EMAS=JKM Warga Emas application elderly parent
# LAYAK_RAG_QUERY_JKM_BKK=Bantuan Kanak-Kanak children household monthly
# LAYAK_RAG_QUERY_LHDN_FORM_B=individual personal relief paragraph 46 RM9000
# LAYAK_RAG_QUERY_I_SARAAN=i-Saraan RM500 government match
# LAYAK_RAG_QUERY_PERKESO_SKSPS=PERKESO SKSPS self-employed contribution plans

# -- Frontend --
PORT=3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# -- Firebase Web SDK --
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=layak-myaifuturehackathon
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=297019726346
NEXT_PUBLIC_FIREBASE_APP_ID=

# -- Firebase Admin --
FIREBASE_ADMIN_KEY=

# -- Phase 11 admin moderation --
# Comma-separated emails (case-insensitive) that bootstrap to `role: admin`
# on first authenticated request. Custom claims propagate after the next
# ID-token refresh (AuthGuard force-refreshes once on admin-route access).
# Leave empty in prod environments that don't grant admin access.
LAYAK_ADMIN_EMAIL_ALLOWLIST=
