{
  "name": "layak-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "test -L .env.local || ln -sf ../.env .env.local",
    "dev": "sh -c '[ -f .env.local ] && { set -a; . ./.env.local; set +a; }; exec next dev --webpack'",
    "prebuild": "test -L .env.local || ln -sf ../.env .env.local",
    "build": "sh -c '[ -f .env.local ] && { set -a; . ./.env.local; set +a; }; exec next build --webpack'",
    "start": "sh -c '[ -f .env.local ] && { set -a; . ./.env.local; set +a; }; exec next start'",
    "lint": "eslint"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-select": "^2.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.12.1",
    "i18next": "^26.0.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.4",
    "react-image-crop": "^11.0.10",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "shadcn": "^4.3.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": "eslint --fix"
  }
}
