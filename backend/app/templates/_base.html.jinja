{#
  Base layout shared by every scheme draft PDF.

  Every page carries a repeated diagonal "DRAFT — NOT SUBMITTED" watermark
  and a legal footer with disclaimers.

  Child templates define three blocks:
    title       — short string used in <title> and page header
    agency      — agency + portal URL line under the title
    body        — main content (form fields, eligibility, values)
#}
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{% block title %}Layak — Draft Packet{% endblock %}</title>
    <style>
      @page {
        size: A4;
        margin: 18mm 18mm 22mm;
        @bottom-center {
          {# `locale.page_footer_css` must not contain `"` — it's inlined into
             a CSS `content:` string. `_LOCALE_STRINGS` enforces this. The
             `generated_at_human` timestamp is appended in a language-neutral
             way since date formatting is already locale-agnostic here. #}
          content: "{{ locale.page_footer_css if locale else 'Generated by Layak — DRAFT, not submitted. You must submit manually via the stated official portal.' }} ({{ generated_at_human }})";
          font-family: 'DejaVu Sans', 'Segoe UI', Arial, sans-serif;
          font-size: 8pt;
          color: #6b6b6b;
        }
        @bottom-right {
          content: "Page " counter(page) " of " counter(pages);
          font-family: 'DejaVu Sans', 'Segoe UI', Arial, sans-serif;
          font-size: 8pt;
          color: #6b6b6b;
        }
      }

      html,
      body {
        margin: 0;
        padding: 0;
        font-family: 'DejaVu Sans', 'Segoe UI', Arial, sans-serif;
        color: #10261a;
        font-size: 10.5pt;
        line-height: 1.45;
      }

      body {
        position: relative;
      }

      /* Repeated diagonal "DRAFT — NOT SUBMITTED" watermark behind the content.
         `position: fixed` makes it repeat on every printed page in WeasyPrint. */
      .watermark-layer {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
      }

      .watermark {
        position: absolute;
        left: 50%;
        font-size: 40pt;
        font-weight: 700;
        letter-spacing: 6pt;
        color: rgba(200, 30, 48, 0.09);
        white-space: nowrap;
        transform-origin: center;
        transform: translate(-50%, -50%) rotate(-30deg);
      }

      .watermark.wm-top { top: 20%; }
      .watermark.wm-mid { top: 50%; }
      .watermark.wm-bot { top: 80%; }

      main {
        position: relative;
        z-index: 1;
      }

      header.packet {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        border-bottom: 2pt solid #10261a;
        padding-bottom: 6pt;
        margin-bottom: 14pt;
      }

      header.packet .brand {
        font-size: 9pt;
        color: #6b6b6b;
        letter-spacing: 0.5pt;
        text-transform: uppercase;
      }

      header.packet h1 {
        margin: 0;
        font-size: 16pt;
        font-weight: 600;
        letter-spacing: 0.3pt;
      }

      header.packet .agency {
        margin-top: 2pt;
        font-size: 9.5pt;
        color: #445566;
      }

      h2 {
        font-size: 11.5pt;
        color: #0a3d7e;
        margin: 14pt 0 6pt;
        padding-bottom: 3pt;
        border-bottom: 0.5pt solid #c7d1dd;
        font-weight: 600;
        letter-spacing: 0.2pt;
      }

      .field-grid {
        display: grid;
        grid-template-columns: 48mm 1fr;
        gap: 4pt 10pt;
        margin: 6pt 0 0;
      }

      .field-grid .label {
        color: #5b6570;
        font-size: 9.5pt;
      }

      .field-grid .value {
        color: #10261a;
        font-weight: 500;
      }

      ul.citations {
        list-style: none;
        padding: 0;
        margin: 4pt 0 0;
      }

      ul.citations li {
        border-left: 2pt solid #0a3d7e;
        padding: 2pt 0 2pt 8pt;
        margin: 4pt 0;
        font-size: 9.5pt;
        line-height: 1.35;
      }

      ul.citations .rule-id {
        color: #0a3d7e;
        font-weight: 600;
      }

      ul.citations .src {
        color: #5b6570;
        display: block;
        margin-top: 1pt;
      }

      table.amounts {
        width: 100%;
        border-collapse: collapse;
        margin-top: 8pt;
      }

      table.amounts th,
      table.amounts td {
        padding: 4pt 6pt;
        text-align: left;
        border-bottom: 0.5pt solid #dde3ea;
      }

      table.amounts th {
        background: #eef2f7;
        color: #0a3d7e;
        font-weight: 600;
        font-size: 9.5pt;
      }

      table.amounts td.num {
        text-align: right;
        font-variant-numeric: tabular-nums;
      }

      table.amounts tr.total td {
        border-top: 1pt solid #10261a;
        border-bottom: none;
        font-weight: 700;
        padding-top: 6pt;
      }

      .callout {
        background: #fff7e6;
        border: 0.5pt solid #e1c779;
        border-radius: 2pt;
        padding: 8pt 10pt;
        margin: 10pt 0 4pt;
        font-size: 9.5pt;
        color: #6a4e0a;
      }

      .signature-block {
        margin-top: 20pt;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18pt;
      }

      .signature-block .slot {
        border-top: 0.6pt solid #10261a;
        padding-top: 3pt;
        font-size: 9pt;
        color: #5b6570;
      }

      .disclaimer {
        margin-top: 16pt;
        padding: 8pt 10pt;
        background: #f4f4f0;
        border-left: 2pt solid #6b6b6b;
        font-size: 8.5pt;
        color: #444;
        line-height: 1.45;
      }
    </style>
  </head>
  <body>
    {# Watermark text localises to the user's language. Gov-form BODY stays
       in source language (BK-01 BM, LHDN forms EN-leaning); only Layak-
       added chrome flips. Pre-Phase-9 callers without `locale` get the
       English default so stale tests / direct template-render callers keep
       working. #}
    <div class="watermark-layer" aria-hidden="true">
      <span class="watermark wm-top">{{ locale.watermark if locale else 'DRAFT — NOT SUBMITTED' }}</span>
      <span class="watermark wm-mid">{{ locale.watermark if locale else 'DRAFT — NOT SUBMITTED' }}</span>
      <span class="watermark wm-bot">{{ locale.watermark if locale else 'DRAFT — NOT SUBMITTED' }}</span>
    </div>

    <main>
      <header class="packet">
        <div>
          <div class="brand">{{ locale.eyebrow if locale else 'Layak · Draft Application Packet' }}</div>
          <h1>{% block header_title %}{{ self.title() }}{% endblock %}</h1>
          <div class="agency">{% block agency %}{% endblock %}</div>
        </div>
        <div style="text-align: right; font-size: 9pt; color: #5b6570;">
          <div>{{ locale.generated_label if locale else 'Generated:' }} {{ generated_at_human }}</div>
          <div>{{ locale.filer_ic_label if locale else 'Filer IC (last 4):' }} {{ profile.ic_last4 }}</div>
        </div>
      </header>

      {% block body %}{% endblock %}

      <section class="disclaimer">
        {# The draft disclaimer localises to the eval's language. Gov-form
           BODY labels (BK-01, JKM18, LHDN forms) stay in their source
           language since the user transcribes them verbatim onto the live
           portal. `locale` is injected by `generate_packet._scheme_context`;
           legacy renders (no `locale` key) fall through to the English
           default below so stale tests don't crash on the missing key. #}
        {% if locale and locale.draft_footer -%}
        {{ locale.draft_footer|safe }}
        {%- else -%}
        This is a <strong>draft application packet</strong> generated by Layak and
        watermarked "DRAFT — NOT SUBMITTED" on every page. Layak is not an official
        government service and is not affiliated with any Malaysian ministry, and
        has not transmitted this document to any Malaysian agency on your behalf.
        Eligibility results in this packet are estimates based on Budget-2026-gazetted
        rates as of {{ generated_at_human }}; the final legal determination rests
        with the relevant agency on application. You must submit this packet
        manually via the stated official portal.
        {%- endif %}
      </section>
    </main>
  </body>
</html>
