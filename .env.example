# Layak local development secrets template.
#
# 1. Copy this file to `.env` at the repo root (gitignored).
# 2. Add the shared Gemini API key to `GEMINI_API_KEY` below.
# 3. Run `pnpm install` once. The frontend `predev` hook creates
#    `frontend/.env.local` as a symlink to the root `.env` on the first `pnpm dev`.
# 4. The backend loads this same file with `python-dotenv` from the repo root.
#
# Production values live in GCP Secret Manager (`gemini-api-key`) and are
# injected at Cloud Run deploy time with `--set-secrets=GEMINI_API_KEY=gemini-api-key:latest`.
# See docs/trd.md section 7 for the split.

# -- Secrets ---------------------------------------------------------------
# Gemini API key. Used only by the backend; the frontend reaches Gemini
# through the backend SSE endpoint, so this key never reaches the browser.
GEMINI_API_KEY=

# -- GCP config ------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=layak-myaifuturehackathon
GOOGLE_CLOUD_LOCATION=asia-southeast1

# Vertex AI Search data store ID, populated after the first run of
# `backend/scripts/seed_vertex_ai_search.py`.
VERTEX_AI_SEARCH_DATA_STORE=

# -- Frontend --------------------------------------------------------------
# Local port for `pnpm dev`, `pnpm build`, and `pnpm start`.
# Next.js reads `PORT` before loading env files, so `frontend/package.json`
# sources `.env.local` in a POSIX shell wrapper before starting Next.
# Override once with `PORT=xxxx pnpm dev`. Cloud Run injects its own `PORT`,
# so this value is ignored there.
PORT=3000

# Backend URL used by the Next.js frontend. The `NEXT_PUBLIC_` prefix exposes
# it to client code. Local default points at the FastAPI dev server; override
# it with the Cloud Run backend URL for preview or production builds.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# -- Firebase Web SDK ------------------------------------------------------
# Client-side Firebase config, pulled via `firebase apps:sdkconfig WEB <app-id>`.
# These values are not secrets — Firebase Web SDK uses them to identify the
# project to Google. Access control is enforced by Firestore rules and the
# backend Admin SDK, not by keeping these opaque.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=layak-myaifuturehackathon
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=297019726346
NEXT_PUBLIC_FIREBASE_APP_ID=

# -- Firebase Admin (backend) ----------------------------------------------
# Service-account JSON (one line, no newlines) consumed by
# `backend/app/auth.py`. In production this arrives via Secret Manager
# `firebase-admin-key`, injected as `FIREBASE_ADMIN_KEY` at Cloud Run deploy
# time. For local dev, export your service-account JSON string here; the
# backend returns 503 on authed endpoints until populated.
FIREBASE_ADMIN_KEY=
