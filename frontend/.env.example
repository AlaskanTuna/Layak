# Layak — example environment template.
# Copy to `.env.local` for local development. Never commit real secrets.
# Production values live in Google Cloud Secret Manager; see docs/trd.md §7.

# Google AI Studio API key (Gemini Pro / Flash / Code Execution).
# Treat this as the primary key for frontend-only prototyping.
GOOGLE_API_KEY=

# Backend-side alias for the same key; set only if the backend expects GEMINI_API_KEY.
# In production this is injected from Secret Manager as `gemini-api-key:latest`.
GEMINI_API_KEY=

# GCP project that owns Cloud Run, Vertex AI, Vertex AI Search, Artifact Registry, Secret Manager.
GOOGLE_CLOUD_PROJECT=

# Cloud Run / Vertex AI region. Candidate: asia-southeast1.
GOOGLE_CLOUD_LOCATION=asia-southeast1

# Vertex AI Search data store ID (set after `backend/scripts/seed_vertex_ai_search.py` runs).
VERTEX_AI_SEARCH_DATA_STORE=

# NOTE: backend stack (FastAPI + ADK-Python) is not yet scaffolded. More env vars
# will be added when the backend lands in Phase 1.
