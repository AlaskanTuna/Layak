rules_version = '2';

// Layak v2 SaaS — Firestore security rules.
// Contract lives in docs/trd.md §5.5 and docs/superpowers/specs/2026-04-21-v2-saas-pivot-design.md §3.3-§3.4.
//
// Invariant: all writes are backend-only (Admin SDK bypasses these rules).
// Client SDK reads are owner-gated; no client writes permitted except `waitlist` create
// for an authenticated user.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read:  if request.auth.uid == userId;
      allow write: if false;
    }

    match /evaluations/{evalId} {
      allow read:  if request.auth.uid == resource.data.userId;
      allow write: if false;
    }

    match /waitlist/{entry} {
      allow create: if request.auth.uid != null;
      allow read, update, delete: if false;
    }
  }
}
