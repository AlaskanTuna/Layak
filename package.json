{
  "name": "layak",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "concurrently -k -n frontend,backend \"pnpm run dev:frontend\" \"pnpm run dev:backend\"",
    "dev:frontend": "pnpm -C frontend dev",
    "dev:backend": "wsl.exe bash -lc \"cd /home/adam/CS/Layak/backend && ./.venv/bin/uvicorn app.main:app --reload --host 0.0.0.0 --port 8080\"",
    "build": "pnpm -C frontend build",
    "start": "pnpm -C frontend start",
    "lint": "pnpm -C frontend lint",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "lint-staged": {
    "*.{md,json,yml,yaml}": "prettier --write",
    "docs/**/*.md": "prettier --write"
  }
}
