# Layak — local development secrets template.
#
# 1. Copy this file to `.env` at the repo root (gitignored).
# 2. Paste the shared Gemini API key into `GEMINI_API_KEY` below.
# 3. Run `pnpm install` once — the frontend `predev` hook auto-creates
#    `frontend/.env.local` as a symlink to this root `.env` on first `pnpm dev`.
# 4. Backend loads this same file via `python-dotenv` pointed at the repo root.
#
# Production values live in GCP Secret Manager (`gemini-api-key`), injected
# at Cloud Run deploy time via `--set-secrets=GEMINI_API_KEY=gemini-api-key:latest`.
# See docs/trd.md §7 for the full split.

# ── Secrets ───────────────────────────────────────────────────────────────
# Gemini API key. Used by the backend only; the frontend reaches Gemini via
# the backend SSE endpoint, so this key never ships to the browser.
GEMINI_API_KEY=

# ── GCP config ────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=layak-myaifuturehackathon
GOOGLE_CLOUD_LOCATION=asia-southeast1

# Vertex AI Search data store ID. Populated after
# `backend/scripts/seed_vertex_ai_search.py` runs for the first time.
VERTEX_AI_SEARCH_DATA_STORE=

# ── Frontend ──────────────────────────────────────────────────────────────
# Port the Next.js dev server (`pnpm dev`) and production server (`pnpm start`)
# bind to locally. Next.js reads `PORT` natively from `.env.local`, so changing
# this value here is enough — no script or flag edits needed. In Cloud Run the
# platform injects its own `PORT` at container start and this value is ignored.
PORT=3000

# Backend URL the Next.js frontend calls. `NEXT_PUBLIC_` prefix exposes it
# to client code. Local default points at the FastAPI dev server; override
# with the Cloud Run backend URL for preview / production builds.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
