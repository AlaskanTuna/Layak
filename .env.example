# Layak local dev env. Copy to .env at repo root. See docs/trd.md §7 for full setup + secrets policy.

# -- GCP / Vertex AI --
GOOGLE_CLOUD_PROJECT=layak-myaifuturehackathon
GOOGLE_CLOUD_LOCATION=asia-southeast1
